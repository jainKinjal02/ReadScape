# ReadScape Environment Variables
# Copy this file to .env.local and fill in your values.
# Find these in: supabase.com → Your Project → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The ANTHROPIC_API_KEY is NOT set here.
# It lives only in Supabase Edge Functions environment variables
# (Project Settings → Edge Functions → Secrets).
# This keeps the key server-side and out of the mobile app bundle.
